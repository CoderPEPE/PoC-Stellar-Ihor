# Stellar TESTNET configuration (public-level only — no secrets belong here in prod).
HORIZON_URL=https://horizon-testnet.stellar.org
# Network passphrase pins the idempotency key to a specific network.
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# How long (seconds) a signed transaction stays valid via timebounds.
# After this, an exact-envelope resubmit returns tx_too_late and we rebuild.
ANCHOR_TTL_SECONDS=180
# Base fee in stroops (1 XLM = 10,000,000 stroops).
BASE_FEE=100
# SQLite path for the system-of-record DB. ':memory:' (default) is ephemeral; set a
# file path to persist. `pnpm run:testnet` falls back to ./data/anchors.db.
# DB_PATH=data/anchors.db

# Only used by the gated live integration test (test/testnet.integration.test.ts).
RUN_TESTNET=1

# Throwaway TESTNET source-account secret seed for `pnpm run:testnet`. If unset, the
# runner generates one and prints it so you can reuse the same DB + account next time.
# TESTNET throwaway only — never a real/mainnet secret.
# STELLAR_SECRET=S...
